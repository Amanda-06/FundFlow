<?xml version="1.0" encoding="utf-8"?>
<!--
    res/xml/file_paths.xml

    Konfigurasi path yang boleh diakses oleh FileProvider.
    Harus cocok dengan lokasi penyimpanan file di
    ExportPdfUseCase & ExportExcelUseCase, yaitu:
        context.getExternalFilesDir(Environment.DIRECTORY_DOCUMENTS)
    yang secara fisik berada di:
        /Android/data/<package_name>/files/Documents/
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <external-files-path
        name="exported_documents"
        path="Documents/" />
</paths>
