    <!-- Tentang FundFlow -->
    <string name="about_title" translatable="false">Tentang FundFlow</string>
    <string name="about_app_desc" translatable="false">FundFlow adalah aplikasi mobile yang dirancang untuk membantu bendahara organisasi mengelola keuangan secara terstruktur, terpusat, dan efisien — mencakup pencatatan iuran, pemasukan, pengeluaran, hingga pelaporan otomatis.</string>
    <string name="about_developed_by" translatable="false">Dikembangkan oleh</string>
    <string name="about_developer_names" translatable="false">Adinda Lestari &amp; Amanda Arva Safaray</string>
    <string name="about_university" translatable="false">Universitas Lambung Mangkurat</string>
    <string name="about_version_label" translatable="false">Versi Aplikasi</string>

    <!-- Pusat Bantuan -->
    <string name="help_title" translatable="false">Pusat Bantuan</string>
    <string name="help_faq_section" translatable="false">Pertanyaan Umum (FAQ)</string>
    <string name="help_contact_section" translatable="false">Hubungi Kami</string>
    <string name="help_contact_email" translatable="false">Kirim Email</string>
    <string name="help_faq_q1" translatable="false">Bagaimana cara menambahkan anggota baru?</string>
    <string name="help_faq_a1" translatable="false">Buka halaman Iuran, lalu klik tombol tambah (+) di pojok kanan bawah untuk membuka Manajemen Anggota, kemudian klik tombol tambah anggota.</string>
    <string name="help_faq_q2" translatable="false">Bagaimana cara mencatat pembayaran iuran?</string>
    <string name="help_faq_a2" translatable="false">Buka halaman Iuran, pilih bulan, lalu klik nama anggota untuk membuka form detail iuran dan ubah status pembayaran.</string>
    <string name="help_faq_q3" translatable="false">Bagaimana cara mengekspor laporan?</string>
    <string name="help_faq_a3" translatable="false">Buka halaman Laporan, pilih jenis laporan yang diinginkan, lalu klik tombol Export PDF atau Export Excel pada preview laporan.</string>
    <string name="help_faq_q4" translatable="false">Apakah data saya tersimpan secara offline?</string>
    <string name="help_faq_a4" translatable="false">Ya, FundFlow menggunakan pendekatan offline-first sehingga data tetap dapat diakses tanpa koneksi internet dan akan disinkronkan saat online.</string>
    <string name="help_faq_q5" translatable="false">Bagaimana cara mengubah bahasa atau tema aplikasi?</string>
    <string name="help_faq_a5" translatable="false">Buka halaman Pengaturan melalui ikon gerigi di Home, lalu pilih Bahasa atau Tema sesuai preferensi Anda.</string>

