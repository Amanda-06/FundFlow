    <!-- Pusat Bantuan -->
    <string name="help_faq_section">Pertanyaan Umum (FAQ)</string>
    <string name="help_contact_section">Hubungi Kami</string>
    <string name="help_contact_email">Kirim Email</string>
    <string name="help_faq_q1">Bagaimana cara menambahkan anggota baru?</string>
    <string name="help_faq_a1">Buka halaman Iuran, lalu klik tombol tambah (+) di pojok kanan bawah untuk membuka Manajemen Anggota, kemudian klik tombol tambah anggota.</string>
    <string name="help_faq_q2">Bagaimana cara mencatat pembayaran iuran?</string>
    <string name="help_faq_a2">Buka halaman Iuran, pilih bulan, lalu klik nama anggota untuk membuka form detail iuran dan ubah status pembayaran.</string>
    <string name="help_faq_q3">Bagaimana cara mengekspor laporan?</string>
    <string name="help_faq_a3">Buka halaman Laporan, pilih jenis laporan yang diinginkan, lalu klik tombol Export PDF atau Export Excel pada preview laporan.</string>
    <string name="help_faq_q4">Apakah data saya tersimpan secara offline?</string>
    <string name="help_faq_a4">Ya, FundFlow menggunakan pendekatan offline-first sehingga data tetap dapat diakses tanpa koneksi internet dan akan disinkronkan saat online.</string>
    <string name="help_faq_q5">Bagaimana cara mengubah bahasa atau tema aplikasi?</string>
    <string name="help_faq_a5">Buka halaman Pengaturan melalui ikon gerigi di Home, lalu pilih Bahasa atau Tema sesuai preferensi Anda.</string>
