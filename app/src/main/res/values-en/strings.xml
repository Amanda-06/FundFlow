    <!-- About FundFlow -->
    <string name="about_title">About FundFlow</string>
    <string name="about_app_desc">FundFlow is a mobile application designed to help organization treasurers manage finances in a structured, centralized, and efficient way — covering dues recording, income, expenses, and automatic reporting.</string>
    <string name="about_developed_by">Developed by</string>
    <string name="about_developer_names">Adinda Lestari &amp; Amanda Arva Safaray</string>
    <string name="about_university">Lambung Mangkurat University</string>
    <string name="about_version_label">App Version</string>

    <!-- Help Center -->
    <string name="help_title">Help Center</string>
    <string name="help_faq_section">Frequently Asked Questions</string>
    <string name="help_contact_section">Contact Us</string>
    <string name="help_contact_email">Send Email</string>
    <string name="help_faq_q1">How do I add a new member?</string>
    <string name="help_faq_a1">Open the Dues page, tap the add (+) button at the bottom right to open Member Management, then tap add member.</string>
    <string name="help_faq_q2">How do I record a dues payment?</string>
    <string name="help_faq_a2">Open the Dues page, select the month, then tap a member\'s name to open the detail form and update the payment status.</string>
    <string name="help_faq_q3">How do I export a report?</string>
    <string name="help_faq_a3">Open the Reports page, select the desired report type, then tap Export PDF or Export Excel on the report preview.</string>
    <string name="help_faq_q4">Is my data stored offline?</string>
    <string name="help_faq_a4">Yes, FundFlow uses an offline-first approach so your data remains accessible without an internet connection and will sync once you\'re online.</string>
    <string name="help_faq_q5">How do I change the app\'s language or theme?</string>
    <string name="help_faq_a5">Open Settings via the gear icon on Home, then choose Language or Theme according to your preference.</string>

